# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hodl

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Whale Alert (https://whale-alert.io)
WHALE_ALERT_API_KEY=

# Polygon.io (https://polygon.io)
POLYGON_API_KEY=

# CryptoPanic (https://cryptopanic.com/developers/api/)
CRYPTOPANIC_API_KEY=

# SEC EDGAR — no key required, but set a contact email for the User-Agent header
SEC_CONTACT_EMAIL=your@email.com

# APNs (token-based auth)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=./certs/AuthKey.p8
APNS_BUNDLE_ID=com.yourname.hodl
# Set to "true" for sandbox, "false" for production
APNS_SANDBOX=true

# Server
PORT=3000
