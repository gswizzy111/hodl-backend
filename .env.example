# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hodl

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Polygon.io — https://polygon.io
POLYGON_API_KEY=

# CryptoPanic — https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# SEC EDGAR — no key required, just set a contact email for the User-Agent header
SEC_CONTACT_EMAIL=your@email.com

# APNs push notifications (token-based auth)
# All four values come from your Apple Developer account
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=./certs/AuthKey.p8
APNS_BUNDLE_ID=com.yourname.hodl
APNS_SANDBOX=true

# Server
PORT=3000
